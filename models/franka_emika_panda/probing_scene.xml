<mujoco model="panda scene">
  <include file="panda.xml"/>
  <option gravity="0 0 0"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <geom
      name="table"
      type="box"
      pos="0.5 0 0.1"
      size="0.35 0.35 0.1"
      rgba="0.6 0.6 0.6 1"/>

    <!-- Small beaker approximation.
         MuJoCo geoms are solid, so the beaker wall is built from
         several thin boxes instead of one hollow cylinder. -->
    <body name="beaker" pos="0.5 0 0.2">
      <!-- Wider bottom to reduce accidental penetration near the base. -->
      <geom
        name="beaker_base"
        type="cylinder"
        pos="0 0 0.008"
        size="0.115 0.008"
        rgba="0.45 0.75 1.0 0.35"/>

      <geom
        name="beaker_wall_0"
        type="box"
        pos="0.090 0 0.065"
        size="0.003 0.040 0.055"
        rgba="0.45 0.75 1.0 0.25"/>
      <geom
        name="beaker_wall_1"
        type="box"
        pos="0.0636 0.0636 0.065"
        quat="0.9238795 0 0 0.3826834"
        size="0.003 0.040 0.055"
        rgba="0.45 0.75 1.0 0.25"/>
      <geom
        name="beaker_wall_2"
        type="box"
        pos="0 0.090 0.065"
        quat="0.7071068 0 0 0.7071068"
        size="0.003 0.040 0.055"
        rgba="0.45 0.75 1.0 0.25"/>
      <geom
        name="beaker_wall_3"
        type="box"
        pos="-0.0636 0.0636 0.065"
        quat="0.3826834 0 0 0.9238795"
        size="0.003 0.040 0.055"
        rgba="0.45 0.75 1.0 0.25"/>
      <geom
        name="beaker_wall_4"
        type="box"
        pos="-0.090 0 0.065"
        size="0.003 0.040 0.055"
        rgba="0.45 0.75 1.0 0.25"/>
      <geom
        name="beaker_wall_5"
        type="box"
        pos="-0.0636 -0.0636 0.065"
        quat="0.9238795 0 0 0.3826834"
        size="0.003 0.040 0.055"
        rgba="0.45 0.75 1.0 0.25"/>
      <geom
        name="beaker_wall_6"
        type="box"
        pos="0 -0.090 0.065"
        quat="0.7071068 0 0 0.7071068"
        size="0.003 0.040 0.055"
        rgba="0.45 0.75 1.0 0.25"/>
      <geom
        name="beaker_wall_7"
        type="box"
        pos="0.0636 -0.0636 0.065"
        quat="0.3826834 0 0 0.9238795"
        size="0.003 0.040 0.055"
        rgba="0.45 0.75 1.0 0.25"/>
    </body>

    <!-- Tested material inside the beaker. Keep the name sample_geom:
         Python code uses it to compute the material surface height. -->
    <body name="sample" pos="0.5 0 0.220">
      <geom
        name="sample_geom"
        type="cylinder"
        size="0.070 0.004"
        solref="0.02 1"
        solimp="0.8 0.95 0.001"
        rgba="0.70 0.45 0.22 1"/>
    </body>
  </worldbody>
</mujoco>
